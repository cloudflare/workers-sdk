{
	"$schema": "../node_modules/oxlint/configuration_schema.json",
	"extends": ["../.oxlintrc.json"],
	"categories": {
		"correctness": "off"
	},
	"jsPlugins": [
		"eslint-plugin-turbo",
		"eslint-plugin-unused-imports",
		{
			"name": "workers-sdk",
			"specifier": "../packages/eslint-config-shared/oxlint-plugin.mjs"
		}
	],
	"overrides": [
		{
			"files": ["**/*.ts", "**/*.mts", "**/*.tsx"],
			"rules": {
				"workers-sdk/no-direct-recursive-rm": "off"
			}
		},
		{
			"files": ["**/*.test.ts", "**/*.test.mts", "**/__tests__/**/*.ts"],
			"rules": {
				"workers-sdk/no-vitest-import-expect": "off"
			}
		}
	]
}
