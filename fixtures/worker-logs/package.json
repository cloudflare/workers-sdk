{
  "name": "@fixture/worker-logs",
  "private": true,
  "scripts": {
    "check:type": "pnpm -w enforce-turbo && tsc",
    "dev": "pnpm -w enforce-turbo && pnpm dev.module",
    "dev.module": "wrangler dev -c wrangler.module.jsonc",
    "dev.service": "wrangler dev -c wrangler.service.jsonc",
