{
	// Modern compat date (>= 2025-04-01) with nodejs_compat
	// This should auto-enable process.env population
	"name": "get-platform-proxy-process-env-modern",
	"main": "src/index.ts",
	"compatibility_date": "2025-04-01",
	"compatibility_flags": ["nodejs_compat"],
	"vars": {
		"MY_VAR": "my-var-value",
		"MY_JSON_VAR": {
			"test": true,
			"nested": { "value": 123 },
		},
	},
}
