{
	"extends": "@cloudflare/workers-tsconfig/tsconfig.json",
	"compilerOptions": {
		// `@cloudflare/workers-types/experimental` is required for the
		// `ctx.exports` API surface and the `Cloudflare.GlobalProps`
		// extension point that `wrangler types` populates.
		"types": [
			"@cloudflare/workers-types/experimental",
			"./worker-configuration.d.ts"
		]
	},
	"include": ["src/**/*.ts", "worker-configuration.d.ts"]
}
