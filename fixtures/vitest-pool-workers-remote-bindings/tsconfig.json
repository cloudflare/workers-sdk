{
	"compilerOptions": {
		"target": "esnext",
		"lib": ["esnext"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": [
			"./worker-configuration.d.ts",
			"@cloudflare/vitest-pool-workers/types"
		],
		"noEmit": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"strict": true
	},
	"include": ["src", "env.d.ts", "test", "test-staging"]
}
