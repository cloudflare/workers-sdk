{
	"name": "vite-worker",
	"main": "./vite-worker/index.ts",
	"compatibility_date": "2024-12-30",
	"services": [
		{
			"binding": "REMOTE",
			"service": "vite-multi-workers",
		},
		{
			"binding": "HEALTH",
			"service": "vite-multi-workers-health",
		},
		{
			"binding": "WRANGLER",
			"service": "wrangler-worker",
		},
	],
}
