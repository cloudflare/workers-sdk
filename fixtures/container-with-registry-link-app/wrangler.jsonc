{
	"name": "container-with-registry-link-app",
	"main": "src/index.ts",
	"compatibility_date": "2025-04-03",
	"containers": [
		{
			"configuration": {
				"image": "registry.cloudchamber.cfdata.org/e2e-test:1.0",
			},
			"class_name": "Container",
			"name": "http2",
			"max_instances": 2,
		},
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "Container",
				"name": "CONTAINER",
			},
		],
	},
	"migrations": [
		{
			"tag": "v1",
			"new_classes": ["Container"],
		},
	],
}
