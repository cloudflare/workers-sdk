	"devDependencies": {
		"@better-auth/stripe": "^1.4.6",
		"@cloudflare/containers": "^0.2.2",
		"@cloudflare/vitest-pool-workers": "workspace:*",
		"@cloudflare/workers-types": "catalog:default",
		"@microlabs/otel-cf-workers": "1.0.0-rc.45",
		"@types/mime-types": "^3.0.1",
