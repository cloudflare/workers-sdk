{
	"name": "@fixture/multi-worker",
	"private": true,
	"scripts": {
		"cf-typegen": "pnpm run \"/^typegen:.*/\"",
		"deploy": "wrangler deploy",
		"start": "wrangler dev -c workers/sentry/wrangler.jsonc -c workers/default/wrangler.jsonc",
		"test:ci": "vitest run",
		"test:watch": "vitest",
		"typegen:default": "wrangler types ./workers/default/worker-configuration.d.ts -c ./workers/default/wrangler.jsonc --no-include-runtime",
		"typegen:sentry": "wrangler types ./workers/sentry/worker-configuration.d.ts -c ./workers/sentry/wrangler.jsonc --no-include-runtime"
	},
	"dependencies": {
		"@sentry/cloudflare": "^10"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:default",
		"vitest": "catalog:default",
		"wrangler": "workspace:*"
	}
}
