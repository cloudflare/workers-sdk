{
	"name": "@cloudflare/containers-shared",
	"version": "0.16.0",
	"private": true,
	"description": "Package that contains shared container functionality for Cloudflare Workers SDK.",
	"homepage": "https://github.com/cloudflare/workers-sdk/tree/main/packages/containers-shared#readme",
	"bugs": {
		"url": "https://github.com/cloudflare/workers-sdk/issues"
	},
	"license": "MIT OR Apache-2.0",
	"author": "wrangler@cloudflare.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/cloudflare/workers-sdk.git",
		"directory": "packages/containers-shared"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./src/knobs": {
			"types": "./dist/src/knobs.d.mts",
			"import": "./dist/src/knobs.mjs"
		},
		"./src/utils": {
			"types": "./dist/src/utils.d.mts",
			"import": "./dist/src/utils.mjs"
		},
		"./src/client/core/request": {
			"types": "./dist/src/client/core/request.d.mts",
			"import": "./dist/src/client/core/request.mjs"
		},
		"./src/client/models/ApplicationAffinityHardwareGeneration": {
			"types": "./dist/src/client/models/ApplicationAffinityHardwareGeneration.d.mts",
			"import": "./dist/src/client/models/ApplicationAffinityHardwareGeneration.mjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check:type": "tsc -p ./tsconfig.json && pnpm run type:tests",
		"deploy": "echo 'no deploy'",
		"test": "vitest",
		"test:ci": "pnpm run test run",
		"test:watch": "pnpm run test --testTimeout=50000 --watch",
		"type:tests": "tsc -p ./tests/tsconfig.json"
	},
	"devDependencies": {
		"@cloudflare/workers-tsconfig": "workspace:*",
		"@cloudflare/workers-utils": "workspace:*",
		"@types/node": "catalog:default",
		"tsdown": "catalog:default",
		"typescript": "catalog:default",
		"vitest": "catalog:default"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"volta": {
		"extends": "../../package.json"
	}
}
