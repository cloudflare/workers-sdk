{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "esnext",
		"esModuleInterop": true,
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"isolatedModules": true,
		"noEmit": true,
		"lib": ["esnext"],
		"incremental": true,
		"strict": true,
		"skipLibCheck": true,
		"types": []
	},
	"exclude": ["node_modules", "vendor"],
	"include": []
}
