{
	"extends": "@cloudflare/workers-tsconfig/tsconfig.json",
	"compilerOptions": {
		"module": "esnext",
		"types": ["node"],
		"tsBuildInfoFile": ".tsbuildinfo",
		// Allows tsdown.config.ts to import "./scripts/deps.ts" with an explicit
		// extension, which Node's native TypeScript config loader requires.
		"allowImportingTsExtensions": true
	},
	"include": ["**/*.ts", "**/*.js"],
	"exclude": ["dist", "node_modules", "**/__tests__", "**/*.test.ts", "tests"]
}
