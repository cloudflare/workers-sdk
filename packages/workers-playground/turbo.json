{
	"$schema": "http://turbo.build/schema.json",
	"extends": ["//"],
	"tasks": {
		"build": {
			"outputs": ["dist/**"],
			"env": [
				"NODE_ENV",
				"VITE_PLAYGROUND_PREVIEW", // used to determine the URL where the preview of the Worker being edited in the playground is hosted.
				"VITE_DEVTOOLS_PREVIEW_URL" // if we are also generating a preview for devtools, the workers-playground build uses it for devtools instead of the default production URL.
			]
		},
		"preview": {}
	}
}
