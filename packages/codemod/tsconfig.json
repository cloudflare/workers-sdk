{
	"extends": "@cloudflare/workers-tsconfig/tsconfig.json",
	"compilerOptions": {
		"module": "esnext",
		"types": ["node"],
		"tsBuildInfoFile": ".tsbuildinfo"
	},
	"include": ["**/*.ts", "**/*.js"],
	"exclude": [
		"dist",
		"node_modules",
		"tests/**/*.test.ts",
		"dev-snippets",
		"dev-snippets-outputs"
	]
}
