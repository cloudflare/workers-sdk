{
	"$schema": "../../node_modules/oxlint/configuration_schema.json",
	"extends": ["../../.oxlintrc.json"],
	"ignorePatterns": [
		"**/*.js",
		"**/dist",
		"scripts/**",
		"tsdown.config.ts",
		"vitest.config.ts",
		"src/__tests__/fixtures/**",
		"playground/**",
		"e2e/**"
	],
	"jsPlugins": [
		"eslint-plugin-turbo",
		"eslint-plugin-unused-imports",
		{
			"name": "workers-sdk",
			"specifier": "../eslint-config-shared/oxlint-plugin.mjs"
		}
	],
	"overrides": [
		{
			"files": ["**/*.ts", "**/*.mts", "**/*.tsx"],
			"rules": {
				"workers-sdk/no-wrangler-named-imports": "error"
			}
		}
	]
}
