{
	"name": "@cloudflare/turbo-r2-archive",
	"version": "0.0.4",
	"private": true,
	"description": "TurboRepo API Compliant Remote Caching w/ Cloudflare Workers using R2",
	"keywords": [
		"cloudflare",
		"remote cache",
		"turborepo",
		"typescript",
		"workers"
	],
	"scripts": {
		"build": "wrangler deploy --dry-run --outdir=./dist",
		"deploy": "wrangler deploy",
		"start": "wrangler dev",
		"type:check": "tsc"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.8.0",
		"hono": "^4.12.5",
		"zod": "catalog:default"
	},
	"devDependencies": {
		"@cloudflare/workers-tsconfig": "workspace:*",
		"wrangler": "workspace:*"
	},
	"volta": {
		"extends": "../../package.json"
	},
	"workers-sdk": {
		"deploy": true
	}
}
