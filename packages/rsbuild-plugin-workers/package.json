{
	"name": "@cloudflare/rsbuild-plugin-workers",
	"version": "0.0.0",
	"description": "Cloudflare Workers plugin for Rsbuild",
	"keywords": [
		"cloudflare",
		"cloudflare-workers",
		"rsbuild",
		"rsbuild-plugin",
		"workers"
	],
	"homepage": "https://github.com/cloudflare/workers-sdk/tree/main/packages/rsbuild-plugin-workers#readme",
	"bugs": {
		"url": "https://github.com/cloudflare/workers-sdk/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/cloudflare/workers-sdk.git",
		"directory": "packages/rsbuild-plugin-workers"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rslib",
		"check:type": "tsc --build",
		"dev": "rslib --watch",
		"test": "vitest run",
		"test:ci": "pnpm test",
		"test:watch": "vitest"
	},
	"dependencies": {
		"miniflare": "workspace:*",
		"wrangler": "workspace:*"
	},
	"devDependencies": {
		"@cloudflare/workers-tsconfig": "workspace:*",
		"@cloudflare/workers-utils": "workspace:*",
		"@microsoft/api-extractor": "^7.52.8",
		"@rsbuild/core": "2.0.9",
		"@rslib/core": "0.22.0",
		"@types/node": "catalog:default",
		"typescript": "catalog:default",
		"vitest": "catalog:default"
	},
	"peerDependencies": {
		"@rsbuild/core": "^2.0.0",
		"wrangler": "workspace:^"
	},
	"workers-sdk": {
		"prerelease": true
	}
}
