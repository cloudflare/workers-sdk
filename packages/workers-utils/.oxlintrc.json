{
	"$schema": "../../node_modules/oxlint/configuration_schema.json",
	"extends": ["../../.oxlintrc.json"],
	"categories": {
		"correctness": "off"
	},
	"ignorePatterns": [
		"vendor",
		"*-dist",
		"emitted-types",
		"**/templates/**/*.*",
		"vitest.config.mts"
	],
	"jsPlugins": [
		"eslint-plugin-turbo",
		"eslint-plugin-unused-imports",
		{
			"name": "workers-sdk",
			"specifier": "../eslint-config-shared/oxlint-plugin.mjs"
		}
	],
	"overrides": [
		{
			"files": ["**/*.ts", "**/*.mts", "**/*.tsx"],
			"rules": {
				"no-console": "error",
				"no-restricted-globals": [
					"error",
					{
						"name": "__dirname",
						"message": "Use `getBasePath()` instead."
					},
					{
						"name": "__filename",
						"message": "Use `getBasePath()` instead."
					},
					{
						"name": "fetch",
						"message": "Use undici's fetch instead"
					}
				]
			}
		},
		{
			"files": [
				"**/*.test.ts",
				"**/test/**/*.ts",
				"**/__tests__/**/*.ts",
				"**/e2e/**/*.ts",
				"tsup/**/*.ts"
			],
			"rules": {
				"no-console": "off",
				"no-restricted-globals": "off"
			}
		}
	]
}
