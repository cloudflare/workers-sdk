{
  "name": "@cloudflare/workers-utils",
  "version": "0.13.0",
  "private": true,
  "description": "Utility package for common Worker operations",
  "homepage": "https://github.com/cloudflare/workers-sdk#readme",
  "bugs": {
    "url": "https://github.com/cloudflare/workers-sdk/issues"
  },
  "license": "MIT OR Apache-2.0",
  "author": "workers-devprod@cloudflare.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudflare/workers-sdk.git",
    "directory": "packages/worker-utils"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "browser": "./dist/browser.mjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./prometheus-metrics": {
      "import": "./dist/prometheus-metrics.mjs",
      "types": "./dist/prometheus-metrics.d.mts"
    },
    "./test-helpers": {
      "import": "./dist/test-helpers/index.mjs",
      "types": "./dist/test-helpers/index.d.mts"
    }
  },
  "scripts": {
    "build": "pnpm -w enforce-turbo && tsup",
    "check:type": "pnpm -w enforce-turbo && tsc -p ./tsconfig.json",
    "deploy": "echo 'no deploy'",
    "dev": "pnpm -w enforce-turbo && concurrently -c black,blue --kill-others-on-fail false \"pnpm tsup --watch src\" \"pnpm run check:type --watch --preserveWatchOutput\"",
    "test": "pnpm -w enforce-turbo && vitest",
    "test:ci": "pnpm -w enforce-turbo && vitest run",
    "type:tests": "tsc -p ./tests/tsconfig.json"
  },
  "devDependencies": {
    "@cloudflare/workers-shared": "workspace:*",
    "@cloudflare/workers-tsconfig": "workspace:*",
    "@cloudflare/workflows-shared": "workspace:*",
    "@types/node": "catalog:default",
    "@vitest/ui": "catalog:default",
    "cloudflare": "^5.2.0",
    "concurrently": "^8.2.2",
    "empathic": "^2.0.0",
    "jsonc-parser": "catalog:default",
    "smol-toml": "catalog:default",
    "ts-dedent": "^2.2.0",
    "tsdown": "^0.15.9",
    "tsup": "8.3.0",
    "typescript": "catalog:default",
    "vitest": "catalog:default",
    "xdg-app-paths": "^8.3.0"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "workers-sdk": {
    "prerelease": true
  }
}
