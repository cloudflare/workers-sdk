{
	"$schema": "../../node_modules/oxlint/configuration_schema.json",
	"extends": ["../../.oxlintrc.json"],
	"ignorePatterns": [
		"**/*.js",
		"vendor",
		"*-dist",
		"pages/functions/template-worker.ts",
		"emitted-types",
		"kv-asset-handler.js",
		"**/templates/**/*.*",
		".tmp",
		"vitest.config.mts",
		"tsup.config.ts"
	],
	"jsPlugins": [
		"eslint-plugin-turbo",
		"eslint-plugin-unused-imports",
		{
			"name": "workers-sdk",
			"specifier": "../eslint-config-shared/oxlint-plugin.mjs"
		}
	],
	"overrides": [
		{
			"files": ["**/*.ts", "**/*.mts", "**/*.tsx"],
			"rules": {
				"no-console": "error",
				"no-restricted-globals": [
					"error",
					{
						"name": "__dirname",
						"message": "Use `getBasePath()` instead."
					},
					{
						"name": "__filename",
						"message": "Use `getBasePath()` instead."
					},
					{
						"name": "fetch",
						"message": "Use undici's fetch instead"
					}
				]
			}
		},
		{
			"files": [
				"**/*.test.ts",
				"**/*.test.mts",
				"**/*.test.tsx",
				"**/test/**/*.ts",
				"**/__tests__/**/*.ts",
				"**/__tests__/**/*.mts",
				"**/__tests__/**/*.tsx",
				"**/e2e/**/*.ts",
				"**/e2e/**/*.mts",
				"scripts/**/*.ts"
			],
			"rules": {
				"no-console": "off",
				"no-restricted-globals": "off"
			}
		},
		{
			"files": [
				"e2e/**/*.ts",
				"src/__tests__/**/helpers.ts",
				"src/__tests__/**/utils.ts",
				"src/__tests__/**/mock-*.ts",
				"src/__tests__/helpers/**/*.ts"
			],
			"rules": {
				"workers-sdk/no-vitest-import-expect": "off"
			}
		}
	]
}
