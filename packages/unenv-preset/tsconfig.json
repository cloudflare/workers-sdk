{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"strict": true,
		"declaration": true,
		"resolveJsonModule": true,
		"types": ["node-unenv"],
		"lib": ["ES2022"]
	},
	"include": ["src/**/*"]
}
